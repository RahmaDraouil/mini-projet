# Flask Configuration
SECRET_KEY=your-secret-key-change-in-production
DEBUG=False
FLASK_ENV=production

# Database Configuration (SQLite - Development)
DATABASE_URL=sqlite:///employee.db

# Database Configuration (MySQL - Production)
# DATABASE_URL=mysql+pymysql://user:password@mysql:3306/employee_db

# MySQL Docker Compose Settings
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=employee_db
MYSQL_USER=user
MYSQL_PASSWORD=password

# Application Settings
APP_NAME=Employee Management System
APP_HOST=0.0.0.0
APP_PORT=5000

# CI/CD Settings (for GitHub Actions)
# These should be set as GitHub Secrets, not in .env
# SERVER_HOST=your-server.com
# SERVER_USER=deploy-user
# SSH_PRIVATE_KEY=<private-key-content>
# SERVER_PORT=22
